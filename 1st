#include<stdio.h>  
int parent[10];  
int find(int vertex) 
  {  
    if (parent[vertex] != vertex)  
     parent[vertex] = find(parent[vertex]);  
     return parent[vertex];  
  }  
void union_sets(int u, int v) 
 {  
   parent[v] = u;  
 }  
 
 int  main() 
 {  
 int i, j, u, v, n, count = 1, min_cost = 0,cost[10][10]; 
 printf("\nKruskal's Algorithm\n");  
 printf("Enter the number of vertices: ");  
 scanf("%d", &n);  
 printf("Enter the cost adjacency matrix:\n");  
 for (i =0; i <n; i++)  
 for (j =0; j < n; j++)  
   scanf("%d", &cost[i][j]);  
 for (i =0;i<n; i++)  
 parent[i] = i;  
 printf("The edges of Minimum Cost Spanning Tree are\n");  
 while (count < n) 
 {  
    int min = 99, a, b;  
    for (i =0; i <n; i++)  
      for (j =0; j < n; j++)  
        if (cost[i][j] < min) 
         {  
           min = cost[i][j];  
           a = i;  
           b = j;  
          }  
    u = find(a);  
    v = find(b);  
    if (u != v) 
    {  
     union_sets(u, v);  
     printf("%d edge (%d,%d) = %d\n", count++, a, b, min);  
     min_cost += min;  
    }  
 

 
   cost[a][b] = cost[b][a] =99;  
 }  
 printf("\nMinimum cost = %d\n", min_cost);  
}
