#include<stdio.h>
#include<time.h>
#include<unistd.h>

void main()
{
    int i, j, n, min, temp, a[10];
    clock_t start, end;
    double time;

    printf("\nSelection Sort\n");
    printf("Enter the number of elements: ");
    scanf("%d", &n);

    printf("Enter the elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    start = clock();

    for(i = 0; i < n - 1; i++)
    {
        usleep(1000);
        min = i;

        for(j = i + 1; j < n; j++)
        {
            if(a[j] < a[min])
                min = j;
        }

        temp = a[i];
        a[i] = a[min];
        a[min] = temp;
    }

    end = clock();
    time = ((double)(end - start)) / CLOCKS_PER_SEC;

    printf("Sorted elements are:\n");
    for(i = 0; i < n; i++)
        printf("%d\t", a[i]);

    printf("\nTotal time taken: %f", time);
}
